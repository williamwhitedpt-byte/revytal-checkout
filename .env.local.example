# ─── Google Sheets ───────────────────────────────────────────────────────────
# Service account JSON (stringified) OR path to credentials file
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"...","token_uri":"..."}

# The spreadsheet ID from the Google Sheet URL
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=orders@yourdomain.com
SMTP_PASS=your_app_password

# Supplier email addresses
SUPPLIER_EMAIL_MEYERPT=orders@meyerpt.com
SUPPLIER_EMAIL_BRACE_DIRECT=orders@bracedirect.com

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app-domain.com
